@model InventarioBI.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<h2>Registrar Nuevo Producto</h2>

<form asp-action="Create">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="CodigoBarras" class="form-label"></label>
                <input asp-for="CodigoBarras" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <input asp-for="Descripcion" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Categoria" class="form-label"></label>
                <select asp-for="Categoria" class="form-select" asp-items="@(new SelectList(ViewBag.Categorias, "IdCategoria", "Nombre"))" required>
                    <option value="">Seleccionar Categoría</option>
                </select>
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Subcategoria" class="form-label"></label>
                <input asp-for="Subcategoria" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="StockActual" class="form-label"></label>
                <input asp-for="StockActual" class="form-control" type="number" />
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="PrecioCosto" class="form-label"></label>
                <input asp-for="PrecioCosto" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="PrecioVenta" class="form-label"></label>
                <input asp-for="PrecioVenta" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Marca" class="form-label"></label>
                <select asp-for="Marca" class="form-select" asp-items="@(new SelectList(ViewBag.Marcas, "IdMarca", "Nombre"))">
                    <option value="">Seleccionar Marca (opcional)</option>
                </select>
                <span asp-validation-for="Marca" class="text-danger"></span>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-success">Guardar Producto</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>