@model IEnumerable<InventarioBI.Models.Producto>

@{
    ViewData["Title"] = "Productos";
    var categorias = (List<InventarioBI.Models.Categoria>)ViewBag.Categorias;
    var marcas = (List<InventarioBI.Models.Marca>)ViewBag.Marcas;
}

<h2>Gestión de Productos</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">+ Nuevo Producto</a>
    <a asp-action="Inactivos" class="btn btn-secondary">👁️ Ver Desactivados</a>
    <a asp-action="ExportarExcel" class="btn btn-success">
        📊 Exportar a Excel
    </a>
</div>

<!-- Barra de Búsqueda y Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label"><i class="fas fa-search"></i> Buscar por código o nombre</label>
                    <input type="text" name="busqueda" class="form-control"
                           placeholder="Escriba código de barras o nombre..."
                           value="@ViewBag.BusquedaActual" />
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="fas fa-tag"></i> Categoría</label>
                    <select name="categoriaId" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.IdCategoria"
                                    selected="@(ViewBag.CategoriaIdActual != null && (int)ViewBag.CategoriaIdActual == cat.IdCategoria)">
                                @cat.Nombre
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="fas fa-industry"></i> Marca</label>
                    <select name="marcaId" class="form-select">
                        <option value="">-- Todas --</option>
                        @foreach (var mar in marcas)
                        {
                            <option value="@mar.IdMarca"
                                    selected="@(ViewBag.MarcaIdActual != null && (int)ViewBag.MarcaIdActual == mar.IdMarca)">
                                @mar.Nombre
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i> Buscar</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual as string) || ViewBag.CategoriaIdActual != null || ViewBag.MarcaIdActual != null)
            {
                <div class="mt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-times"></i> Limpiar filtros</a>
                    <span class="ms-2 text-muted">@Model.Count() resultado(s) encontrado(s)</span>
                </div>
            }
        </form>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código de Barras</th>
            <th>Descripción</th>
            <th>Categoría</th>
            <th>Marca</th>
            <th>Stock Actual</th>
            <th>Precio Costo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CodigoBarras</td>
                <td>@item.Descripcion</td>
                <td>@(item.CategoriaNavigation?.Nombre ?? "—")</td>
                <td>@(item.MarcaNavigation?.Nombre ?? "—")</td>
                <td><strong>@item.StockActual</strong></td>
                <td>S/ @item.PrecioCosto</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdProducto" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.IdProducto" class="btn btn-danger btn-sm">Desactivar</a>
                </td>
            </tr>
        }
    </tbody>
</table>