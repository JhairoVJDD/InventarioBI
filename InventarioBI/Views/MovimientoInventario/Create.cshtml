@model InventarioBI.Models.MovimientoInventario

@{
    ViewData["Title"] = "Nuevo Movimiento de Inventario";
}

<h2>Nuevo Movimiento de Inventario</h2>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">

            <div class="form-group mb-3">
                <label class="form-label">Producto</label>
                <select asp-for="IdProducto" class="form-select" required>
                    <option value="">-- Seleccione un producto --</option>
                    @foreach (var item in ViewBag.Productos)
                    {
                        <option value="@item.IdProducto">
                            @item.Descripcion (Stock actual: @item.StockActual)
                        </option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Tienda</label>
                <select asp-for="IdTienda" class="form-select" required>
                    <option value="">-- Seleccione una tienda --</option>
                    @foreach (var item in ViewBag.Tiendas)
                    {
                        <option value="@item.IdTienda">
                            @item.Nombre
                        </option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Tipo de Movimiento</label>
                <select asp-for="TipoMovimiento" class="form-select" required>
                    <option value="">-- Seleccione --</option>
                    <option value="ENTRADA">ENTRADA (Compra / Recepción)</option>
                    <option value="SALIDA">SALIDA (Venta / Consumo)</option>
                    <option value="AJUSTE">AJUSTE (Corrección)</option>
                    <option value="MERMA">MERMA (Pérdida / Daño)</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Cantidad" class="form-label"></label>
                <input asp-for="Cantidad" class="form-control" type="number" step="0.01" required />
                <span asp-validation-for="Cantidad" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Motivo" class="form-label"></label>
                <textarea asp-for="Motivo" class="form-control" rows="3"></textarea>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success">Registrar Movimiento</button>
        <a asp-action="Index" class="btn btn-secondary">Volver a Lista</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}