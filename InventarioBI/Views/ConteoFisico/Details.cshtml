@model InventarioBI.Models.ConteoFisico

@{
    ViewData["Title"] = "Detalle de Conteo Físico";
}

<h2>Detalle de Conteo Físico</h2>

<div class="card">
    <div class="card-body">
        <h5>@Model.Producto?.Descripcion</h5>
        
        @{
            var tiendasDict = (Dictionary<int, string>)ViewBag.Tiendas;
            var tiendaNombre = tiendasDict != null && tiendasDict.ContainsKey(Model.IdTienda) ? tiendasDict[Model.IdTienda] : "Desconocida";
        }
        <div class="row mt-3">
            <div class="col-md-6">
                <p><strong>Tienda:</strong> @tiendaNombre</p>
                <p><strong>Fecha del Conteo:</strong> @Model.FechaConteo.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Stock según Sistema:</strong> @Model.StockSistema</p>
                <p><strong>Stock Físico:</strong> @Model.StockFisico</p>
            </div>
            <div class="col-md-6">
                <p>
                    <strong>Diferencia:</strong>
                    <span class="fw-bold @(Model.Diferencia != 0 ? "text-danger" : "text-success")">
                        @Model.Diferencia
                    </span>
                </p>
                <p>
                    <strong>Estado:</strong>
                    <span class="badge @(Model.Estado == "Pendiente" ? "bg-warning" : "bg-success")">
                        @Model.Estado
                    </span>
                </p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Comentario))
        {
            <div class="mt-3">
                <strong>Comentario:</strong>
                <p>@Model.Comentario</p>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    <a asp-action="Gestionar" asp-route-id="@Model.IdConteo" class="btn btn-primary">Gestionar Anomalía</a>
</div>