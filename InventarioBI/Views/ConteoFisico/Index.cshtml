@model IEnumerable<InventarioBI.Models.ConteoFisico>

<h2>Conteos Físicos Realizados</h2>
<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Nuevo Conteo</a>
    <a asp-action="ExportarExcel" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
    </a>
</div>
<a asp-action="Create" class="btn btn-primary mb-3">Nuevo Conteo</a>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Producto</th>
            <th>Stock Sistema</th>
            <th>Stock Físico</th>
            <th>Diferencia</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaConteo.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.Producto?.Descripcion</td>
                <td>@item.StockSistema</td>
                <td>@item.StockFisico</td>
                <td>
                    <strong class="@(item.Diferencia != 0 ? "text-danger" : "text-success")">
                        @item.Diferencia
                    </strong>
                </td>
                <td>
                    <span class="badge @(item.Estado == "Pendiente" ? "bg-warning" : "bg-success")">
                        @item.Estado
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.IdConteo" class="btn btn-info btn-sm">Ver</a>
                </td>
            </tr>
        }
    </tbody>
</table>
