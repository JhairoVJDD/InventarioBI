@model InventarioBI.ViewModels.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Content Header -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Dashboard <small>Control de Inventario BI</small></h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- KPI Cards -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@Model.TotalProductos</h3>
                        <p>Total Productos</p>
                    </div>
                    <div class="icon"><i class="fas fa-boxes"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>S/ @Model.StockTotalValorizado.ToString("N0")</h3>
                        <p>Stock Valorizado</p>
                    </div>
                    <div class="icon"><i class="fas fa-dollar-sign"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.AnomaliasPendientes</h3>
                        <p>Anomalías Pendientes</p>
                    </div>
                    <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.TotalMovimientos</h3>
                        <p>Total Movimientos</p>
                    </div>
                    <div class="icon"><i class="fas fa-exchange-alt"></i></div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Tendencia de Movimientos</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="salesChart" style="height: 300px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">Movimientos por Tipo</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="tipoMovimientosChart" style="height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimos Conteos -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Últimos Conteos Físicos</h3>
                    </div>
                    <div class="card-body table-responsive">
                        @if (Model.UltimosConteos != null && Model.UltimosConteos.Any())
                        {
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Producto</th>
                                        <th>Sistema</th>
                                        <th>Físico</th>
                                        <th>Diferencia</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.UltimosConteos)
                                    {
                                        <tr>
                                            <td>@item.FechaConteo.ToString("dd/MM/yyyy")</td>
                                            <td>@item.Producto?.Descripcion</td>
                                            <td>@item.StockSistema</td>
                                            <td>@item.StockFisico</td>
                                            <td class="@(item.Diferencia != 0 ? "text-danger fw-bold" : "text-success")">@item.Diferencia</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Reuse your previous chart logic
        const ctxTipo = document.getElementById('tipoMovimientosChart');
        if (ctxTipo) {
            new Chart(ctxTipo, { type: 'doughnut', data: { labels: [], datasets: [{ data: [] }] } });
        }
    </script>
}