@model InventarioBI.ViewModels.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Content Header -->
<div class="content-header" style="padding:20px 24px 0;">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h1 style="font-size:1.6rem;font-weight:700;color:#f1f5f9;margin:0;">
                    Dashboard
                    <small style="font-size:0.85rem;color:rgba(255,255,255,0.45);font-weight:400;margin-left:8px;">Control de Inventario BI</small>
                </h1>
            </div>
            <div class="col-sm-6 text-end">
                <span style="font-size:0.8rem;color:rgba(255,255,255,0.4);">
                    <i class="fas fa-clock"></i> Última actualización: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>
        </div>
    </div>
</div>

<section class="content" style="padding:12px 24px 24px;">
    <div class="container-fluid">

        <!-- ══════════ KPI CARDS ══════════ -->
        <div class="row" style="margin-bottom:24px;">
            <!-- KPI 1: Total Productos -->
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="kpi-box" style="background: linear-gradient(135deg, #10b981, #059669); position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 20px rgba(16,185,129,0.25); transition: all 0.3s ease; padding: 20px 20px 48px 20px; color: white; cursor: pointer;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 12px 30px rgba(16,185,129,0.4)'; this.querySelector('.kpi-icon').style.transform='scale(1.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(16,185,129,0.25)'; this.querySelector('.kpi-icon').style.transform='scale(1)';">
                    <div style="z-index: 2; position: relative;">
                        <h3 style="font-size: 2.3rem; font-weight: 700; margin: 0; line-height: 1.2;">@Model.TotalProductos</h3>
                        <p style="font-size: 0.9rem; font-weight: 500; opacity: 0.9; margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.5px;">Total Productos</p>
                    </div>
                    <i class="fas fa-boxes kpi-icon" style="position: absolute; right: 16px; top: 16px; font-size: 4rem; opacity: 0.22; color: #fff; transition: all 0.3s ease; z-index: 1;"></i>
                    <a href="@Url.Action("Index","Producto")" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0, 0, 0, 0.15); color: rgba(255, 255, 255, 0.85); text-align: center; padding: 8px 0; font-size: 0.8rem; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.2s; z-index: 3;"
                       onmouseover="this.style.background='rgba(0,0,0,0.25)'; this.style.color='#fff';"
                       onmouseout="this.style.background='rgba(0,0,0,0.15)'; this.style.color='rgba(255,255,255,0.85)';">
                        Más información <i class="fas fa-arrow-circle-right" style="font-size: 0.85rem;"></i>
                    </a>
                </div>
            </div>

            <!-- KPI 2: Stock Valorizado -->
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="kpi-box" style="background: linear-gradient(135deg, #06b6d4, #0891b2); position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 20px rgba(6,182,212,0.25); transition: all 0.3s ease; padding: 20px 20px 48px 20px; color: white; cursor: pointer;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 12px 30px rgba(6,182,212,0.4)'; this.querySelector('.kpi-icon').style.transform='scale(1.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(6,182,212,0.25)'; this.querySelector('.kpi-icon').style.transform='scale(1)';">
                    <div style="z-index: 2; position: relative;">
                        <h3 style="font-size: 1.8rem; font-weight: 700; margin: 0; line-height: 1.4;">S/ @Model.StockTotalValorizado.ToString("N0")</h3>
                        <p style="font-size: 0.9rem; font-weight: 500; opacity: 0.9; margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.5px;">Stock Valorizado</p>
                    </div>
                    <i class="fas fa-coins kpi-icon" style="position: absolute; right: 16px; top: 16px; font-size: 4rem; opacity: 0.22; color: #fff; transition: all 0.3s ease; z-index: 1;"></i>
                    <a href="@Url.Action("Index","Producto")" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0, 0, 0, 0.15); color: rgba(255, 255, 255, 0.85); text-align: center; padding: 8px 0; font-size: 0.8rem; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.2s; z-index: 3;"
                       onmouseover="this.style.background='rgba(0,0,0,0.25)'; this.style.color='#fff';"
                       onmouseout="this.style.background='rgba(0,0,0,0.15)'; this.style.color='rgba(255,255,255,0.85)';">
                        Más información <i class="fas fa-arrow-circle-right" style="font-size: 0.85rem;"></i>
                    </a>
                </div>
            </div>

            <!-- KPI 3: Anomalías Pendientes -->
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="kpi-box" style="background: linear-gradient(135deg, #f59e0b, #d97706); position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 20px rgba(245,158,11,0.25); transition: all 0.3s ease; padding: 20px 20px 48px 20px; color: white; cursor: pointer;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 12px 30px rgba(245,158,11,0.4)'; this.querySelector('.kpi-icon').style.transform='scale(1.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(245,158,11,0.25)'; this.querySelector('.kpi-icon').style.transform='scale(1)';">
                    <div style="z-index: 2; position: relative;">
                        <h3 style="font-size: 2.3rem; font-weight: 700; margin: 0; line-height: 1.2;">@Model.AnomaliasPendientes</h3>
                        <p style="font-size: 0.9rem; font-weight: 500; opacity: 0.9; margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.5px;">Anomalías Pendientes</p>
                    </div>
                    <i class="fas fa-exclamation-triangle kpi-icon" style="position: absolute; right: 16px; top: 16px; font-size: 4rem; opacity: 0.22; color: #fff; transition: all 0.3s ease; z-index: 1;"></i>
                    <a href="@Url.Action("Anomalias","ConteoFisico")" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0, 0, 0, 0.15); color: rgba(255, 255, 255, 0.85); text-align: center; padding: 8px 0; font-size: 0.8rem; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.2s; z-index: 3;"
                       onmouseover="this.style.background='rgba(0,0,0,0.25)'; this.style.color='#fff';"
                       onmouseout="this.style.background='rgba(0,0,0,0.15)'; this.style.color='rgba(255,255,255,0.85)';">
                        Más información <i class="fas fa-arrow-circle-right" style="font-size: 0.85rem;"></i>
                    </a>
                </div>
            </div>

            <!-- KPI 4: Total Movimientos -->
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="kpi-box" style="background: linear-gradient(135deg, #ef4444, #dc2626); position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 20px rgba(239,68,68,0.25); transition: all 0.3s ease; padding: 20px 20px 48px 20px; color: white; cursor: pointer;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 12px 30px rgba(239,68,68,0.4)'; this.querySelector('.kpi-icon').style.transform='scale(1.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(239,68,68,0.25)'; this.querySelector('.kpi-icon').style.transform='scale(1)';">
                    <div style="z-index: 2; position: relative;">
                        <h3 style="font-size: 2.3rem; font-weight: 700; margin: 0; line-height: 1.2;">@Model.TotalMovimientos</h3>
                        <p style="font-size: 0.9rem; font-weight: 500; opacity: 0.9; margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.5px;">Total Movimientos</p>
                    </div>
                    <i class="fas fa-exchange-alt kpi-icon" style="position: absolute; right: 16px; top: 16px; font-size: 4rem; opacity: 0.22; color: #fff; transition: all 0.3s ease; z-index: 1;"></i>
                    <a href="@Url.Action("Index","MovimientoInventario")" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0, 0, 0, 0.15); color: rgba(255, 255, 255, 0.85); text-align: center; padding: 8px 0; font-size: 0.8rem; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.2s; z-index: 3;"
                       onmouseover="this.style.background='rgba(0,0,0,0.25)'; this.style.color='#fff';"
                       onmouseout="this.style.background='rgba(0,0,0,0.15)'; this.style.color='rgba(255,255,255,0.85)';">
                        Más información <i class="fas fa-arrow-circle-right" style="font-size: 0.85rem;"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- ══════════ CHARTS ROW ══════════ -->
        <div class="row" style="margin-bottom:24px;">
            <!-- Chart: Top Productos con más Movimientos (Bar) -->
            <div class="col-lg-8 col-12 mb-3">
                <div class="card" style="height:100%;">
                    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                        <h3 class="card-title" style="margin:0;"><i class="fas fa-chart-bar" style="color:#3b82f6;margin-right:8px;"></i>Top Productos con más Movimientos</h3>
                    </div>
                    <div class="card-body" style="padding:20px;">
                        <canvas id="topProductosChart" style="height:300px;max-height:300px;"></canvas>
                    </div>
                </div>
            </div>

            <!-- Chart: Movimientos por Tipo (Doughnut) -->
            <div class="col-lg-4 col-12 mb-3">
                <div class="card" style="height:100%;">
                    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                        <h3 class="card-title" style="margin:0;"><i class="fas fa-chart-pie" style="color:#8b5cf6;margin-right:8px;"></i>Movimientos por Tipo</h3>
                    </div>
                    <div class="card-body" style="display:flex;align-items:center;justify-content:center;padding:20px;">
                        <canvas id="tipoMovimientosChart" style="max-height:300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════ STATS ROW ══════════ -->
        <div class="row" style="margin-bottom:24px;">
            <!-- Stats card 1: Tiendas -->
            <div class="col-lg-4 col-md-6 col-12 mb-3">
                <a href="@Url.Action("Index","Tienda")" style="text-decoration:none;display:block;">
                    <div style="background:rgba(15,25,50,0.85);border:1px solid rgba(59,130,246,0.12);border-radius:12px;padding:24px 20px;text-align:center;backdrop-filter:blur(12px);transition:all 0.3s ease;cursor:pointer;"
                         onmouseover="this.style.transform='translateY(-4px)';this.style.background='rgba(20,35,70,0.9)';this.style.borderColor='rgba(59,130,246,0.3)';"
                         onmouseout="this.style.transform='translateY(0)';this.style.background='rgba(15,25,50,0.85)';this.style.borderColor='rgba(59,130,246,0.12)';">
                        <i class="fas fa-store" style="font-size:2.2rem;color:#3b82f6;margin-bottom:10px;"></i>
                        <h4 style="font-size:1.9rem;font-weight:700;color:#f1f5f9;margin:4px 0;">@Model.TotalTiendas</h4>
                        <p style="color:rgba(255,255,255,0.55);font-size:0.85rem;margin:0;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;">Tiendas Activas</p>
                    </div>
                </a>
            </div>

            <!-- Stats card 2: Categorías -->
            <div class="col-lg-4 col-md-6 col-12 mb-3">
                <a href="@Url.Action("Index","Producto")" style="text-decoration:none;display:block;">
                    <div style="background:rgba(15,25,50,0.85);border:1px solid rgba(59,130,246,0.12);border-radius:12px;padding:24px 20px;text-align:center;backdrop-filter:blur(12px);transition:all 0.3s ease;cursor:pointer;"
                         onmouseover="this.style.transform='translateY(-4px)';this.style.background='rgba(20,35,70,0.9)';this.style.borderColor='rgba(59,130,246,0.3)';"
                         onmouseout="this.style.transform='translateY(0)';this.style.background='rgba(15,25,50,0.85)';this.style.borderColor='rgba(59,130,246,0.12)';">
                        <i class="fas fa-tags" style="font-size:2.2rem;color:#8b5cf6;margin-bottom:10px;"></i>
                        <h4 style="font-size:1.9rem;font-weight:700;color:#f1f5f9;margin:4px 0;">@Model.TotalCategorias</h4>
                        <p style="color:rgba(255,255,255,0.55);font-size:0.85rem;margin:0;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;">Categorías Activas</p>
                    </div>
                </a>
            </div>

            <!-- Stats card 3: Conteos -->
            <div class="col-lg-4 col-md-6 col-12 mb-3">
                <a href="@Url.Action("Index","ConteoFisico")" style="text-decoration:none;display:block;">
                    <div style="background:rgba(15,25,50,0.85);border:1px solid rgba(59,130,246,0.12);border-radius:12px;padding:24px 20px;text-align:center;backdrop-filter:blur(12px);transition:all 0.3s ease;cursor:pointer;"
                         onmouseover="this.style.transform='translateY(-4px)';this.style.background='rgba(20,35,70,0.9)';this.style.borderColor='rgba(59,130,246,0.3)';"
                         onmouseout="this.style.transform='translateY(0)';this.style.background='rgba(15,25,50,0.85)';this.style.borderColor='rgba(59,130,246,0.12)';">
                        <i class="fas fa-clipboard-check" style="font-size:2.2rem;color:#10b981;margin-bottom:10px;"></i>
                        <h4 style="font-size:1.9rem;font-weight:700;color:#f1f5f9;margin:4px 0;">@Model.UltimosConteos.Count</h4>
                        <p style="color:rgba(255,255,255,0.55);font-size:0.85rem;margin:0;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;">Últimos Conteos</p>
                    </div>
                </a>
            </div>
        </div>

        <!-- ══════════ ÚLTIMOS CONTEOS TABLE ══════════ -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
                        <h3 class="card-title" style="margin:0;"><i class="fas fa-clipboard-list" style="color:#10b981;margin-right:8px;"></i>Últimos Conteos Físicos</h3>
                        <a href="@Url.Action("Index","ConteoFisico")" style="font-size:0.8rem;color:#60a5fa;text-decoration:none;">
                            Ver todos <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                    <div class="card-body table-responsive" style="padding:0;">
                        @if (Model.UltimosConteos != null && Model.UltimosConteos.Any())
                        {
                            <table class="table" style="margin:0;">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Producto</th>
                                        <th>Sistema</th>
                                        <th>Físico</th>
                                        <th>Diferencia</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.UltimosConteos)
                                    {
                                        <tr>
                                            <td>@item.FechaConteo.ToString("dd/MM/yyyy")</td>
                                            <td>@item.Producto?.Descripcion</td>
                                            <td>@item.StockSistema</td>
                                            <td>@item.StockFisico</td>
                                            <td>
                                                <span style="font-weight:600;color:@(item.Diferencia != 0 ? "#f87171" : "#4ade80");">
                                                    @item.Diferencia
                                                </span>
                                            </td>
                                            <td>
                                                @if (item.Estado == "Pendiente")
                                                {
                                                    <span class="badge" style="background:rgba(251,191,36,0.2);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);">Pendiente</span>
                                                }
                                                else if (item.Estado == "Investigado")
                                                {
                                                    <span class="badge" style="background:rgba(96,165,250,0.2);color:#60a5fa;border:1px solid rgba(96,165,250,0.3);">Investigado</span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background:rgba(74,222,128,0.2);color:#4ade80;border:1px solid rgba(74,222,128,0.3);">Resuelto</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div style="padding:40px;text-align:center;color:rgba(255,255,255,0.35);">
                                <i class="fas fa-inbox" style="font-size:2.5rem;margin-bottom:12px;display:block;"></i>
                                No hay conteos físicos registrados aún.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ── Chart.js Global Config (Dark Theme) ──
        Chart.defaults.color = 'rgba(255,255,255,0.6)';
        Chart.defaults.borderColor = 'rgba(59,130,246,0.08)';
        Chart.defaults.font.family = "'Inter', sans-serif";

        // ── 1. Top Productos Bar Chart ──
        const topLabels = @Html.Raw(JsonSerializer.Serialize(Model.TopProductosMovimiento.Select(t => t.Producto)));
        const topData = @Html.Raw(JsonSerializer.Serialize(Model.TopProductosMovimiento.Select(t => t.TotalMovimientos)));

        const ctxTop = document.getElementById('topProductosChart');
        if (ctxTop) {
            const gradientBar = ctxTop.getContext('2d').createLinearGradient(0, 0, 0, 300);
            gradientBar.addColorStop(0, 'rgba(59,130,246,0.8)');
            gradientBar.addColorStop(1, 'rgba(139,92,246,0.4)');

            new Chart(ctxTop, {
                type: 'bar',
                data: {
                    labels: topLabels,
                    datasets: [{
                        label: 'Movimientos',
                        data: topData,
                        backgroundColor: gradientBar,
                        borderColor: 'rgba(59,130,246,0.6)',
                        borderWidth: 1,
                        borderRadius: 8,
                        barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(59,130,246,0.06)' },
                            ticks: { stepSize: 1 }
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                maxRotation: 15,
                                font: { size: 11 }
                            }
                        }
                    }
                }
            });
        }

        // ── 2. Movimientos por Tipo Doughnut Chart ──
        const tipoLabels = @Html.Raw(JsonSerializer.Serialize(Model.MovimientosPorTipo.Select(m => m.Tipo)));
        const tipoData = @Html.Raw(JsonSerializer.Serialize(Model.MovimientosPorTipo.Select(m => m.Cantidad)));

        const tipoColors = {
            'ENTRADA': '#4ade80',
            'SALIDA': '#f87171',
            'AJUSTE': '#60a5fa',
            'MERMA': '#fbbf24'
        };
        const bgColors = tipoLabels.map(l => tipoColors[l] || '#8b5cf6');

        const ctxTipo = document.getElementById('tipoMovimientosChart');
        if (ctxTipo) {
            new Chart(ctxTipo, {
                type: 'doughnut',
                data: {
                    labels: tipoLabels,
                    datasets: [{
                        data: tipoData,
                        backgroundColor: bgColors,
                        borderColor: '#0f1932',
                        borderWidth: 3,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 16,
                                usePointStyle: true,
                                pointStyleWidth: 10,
                                font: { size: 12 }
                            }
                        }
                    }
                }
            });
        }
    </script>
}