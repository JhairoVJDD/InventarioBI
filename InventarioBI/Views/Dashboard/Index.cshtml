@model InventarioBI.ViewModels.DashboardViewModel
@using System.Text.Json
@using System.Linq
@{
    ViewData["Title"] = "Dashboard - Business Intelligence";
}

<h2 class="mb-4">📊 Dashboard - Control de Inventario BI</h2>

<!-- KPIs -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <h5>Total Productos</h5>
                <h2>@Model.TotalProductos</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body text-center">
                <h5>Stock Valorizado</h5>
                <h2>S/ @Model.StockTotalValorizado.ToString("N2")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body text-center">
                <h5>Anomalías Pendientes</h5>
                <h2>@Model.AnomaliasPendientes</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body text-center">
                <h5>Total Movimientos</h5>
                <h2>@Model.TotalMovimientos</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Gráfico 1: Movimientos por Tipo -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Movimientos por Tipo</div>
            <div class="card-body">
                <canvas id="tipoMovimientosChart" height="250"></canvas>
            </div>
        </div>
    </div>

    <!-- Gráfico 2: Top Productos con más movimientos -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Productos con Más Movimientos</div>
            <div class="card-body">
                <canvas id="topProductosChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Últimos Conteos Físicos -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Últimos Conteos Físicos</h5>
            </div>
            <div class="card-body">
                @if (Model.UltimosConteos != null && Model.UltimosConteos.Any())
                {
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Producto</th>
                                <th>Stock Sistema</th>
                                <th>Stock Físico</th>
                                <th>Diferencia</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.UltimosConteos)
                            {
                                <tr>
                                    <td>@item.FechaConteo.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.Producto?.Descripcion</td>
                                    <td>@item.StockSistema</td>
                                    <td>@item.StockFisico</td>
                                    <td class="fw-bold @(item.Diferencia != 0 ? "text-danger" : "text-success")">
                                        @item.Diferencia
                                    </td>
                                    <td>
                                        <span class="badge @(item.Estado == "Pendiente" ? "bg-warning" : "bg-success")">
                                            @item.Estado
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay conteos físicos registrados aún.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        var tipos = new List<string>();
        var cantidades = new List<int>();
        if (Model?.MovimientosPorTipo != null)
        {
            foreach (var m in Model.MovimientosPorTipo)
            {
                tipos.Add(Convert.ToString(m.Tipo));
                cantidades.Add(Convert.ToInt32(m.Cantidad));
            }
        }
        var tiposJson = JsonSerializer.Serialize(tipos);
        var cantidadesJson = JsonSerializer.Serialize(cantidades);

        var topLabels = new List<string>();
        var topData = new List<int>();
        if (Model?.TopProductosMovimiento != null)
        {
            foreach (var p in Model.TopProductosMovimiento)
            {
                topLabels.Add(Convert.ToString(p.Producto));
                topData.Add(Convert.ToInt32(p.TotalMovimientos));
            }
        }
        var topLabelsJson = JsonSerializer.Serialize(topLabels);
        var topDataJson = JsonSerializer.Serialize(topData);
    }
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Gráfico 1: Movimientos por Tipo
        new Chart(document.getElementById('tipoMovimientosChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(tiposJson),
                datasets: [{
                    data: @Html.Raw(cantidadesJson),
                    backgroundColor: ['#0d6efd', '#dc3545', '#ffc107', '#198754', '#6f42c1']
                }]
            }
        });

        // Gráfico 2: Top Productos
        new Chart(document.getElementById('topProductosChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(topLabelsJson),
                datasets: [{
                    label: 'Cantidad de Movimientos',
                    data: @Html.Raw(topDataJson),
                    backgroundColor: '#0d6efd'
                }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}